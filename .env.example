# Create `.env.local` in the project root for local development.
# For Vercel, add these same variables in Project Settings -> Environment Variables.
# OPENAI_API_KEY enables live AI analysis. If omitted, JobCraftor will fall back to its validated mock analysis engine.
OPENAI_API_KEY=

# Optional: override the default model used by the server-side analyzer.
OPENAI_MODEL=gpt-4o-mini
